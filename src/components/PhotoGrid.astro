<section class="photo-grid">
  <div class="photo-grid__inner">
    <div class="photo-grid__item reveal">
      <div class="photo-placeholder">
        <span>Wedding Portrait</span>
      </div>
    </div>
    <div class="photo-grid__item reveal">
      <div class="photo-placeholder">
        <span>Couple at Reception</span>
      </div>
    </div>
    <div class="photo-grid__text reveal">
      <h3>Studio-grade portraits<br />at your event</h3>
      <p class="photo-grid__subtitle"><em>Elegant & timeless</em></p>
    </div>
    <div class="photo-grid__item reveal">
      <div class="photo-placeholder">
        <span>Family Photo</span>
      </div>
    </div>
  </div>
</section>

<style>
  .photo-grid {
    padding: 0 var(--side-padding) var(--section-padding);
  }

  .photo-grid__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .photo-grid__item,
  .photo-grid__text {
    flex: 1;
    min-width: 0;
  }

  .photo-placeholder {
    background: var(--color-bg-light);
    aspect-ratio: 4/5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .photo-placeholder span {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-accent);
    font-size: 1rem;
  }

  .photo-grid__text {
    text-align: center;
    padding: 24px 16px;
  }

  .photo-grid__text h3 {
    margin-bottom: 12px;
  }

  .photo-grid__subtitle {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .photo-grid__inner {
      flex-wrap: wrap;
    }

    .photo-grid__item,
    .photo-grid__text {
      flex: 1 1 calc(50% - 24px);
    }
  }

  @media (max-width: 480px) {
    .photo-grid__item,
    .photo-grid__text {
      flex: 1 1 100%;
    }
  }
</style>
