---

<section class="photo-grid">
  <div class="photo-grid__inner">
    <div class="photo-grid__large reveal">
      <div class="photo-placeholder photo-placeholder--tall">
        <span>Wedding Portrait</span>
      </div>
    </div>
    <div class="photo-grid__stack">
      <div class="photo-grid__small reveal">
        <div class="photo-placeholder">
          <span>Couple at Reception</span>
        </div>
      </div>
      <div class="photo-grid__text reveal">
        <h3>Studio-grade portraits<br />at your event</h3>
        <p class="photo-grid__subtitle"><em>Elegant & timeless</em></p>
      </div>
      <div class="photo-grid__small reveal">
        <div class="photo-placeholder">
          <span>Family Photo</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .photo-grid {
    padding: 0 var(--side-padding) var(--section-padding);
  }

  .photo-grid__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .photo-grid__stack {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 80px;
  }

  .photo-grid__text {
    text-align: center;
    padding: 48px 24px;
  }

  .photo-grid__text h3 {
    margin-bottom: 12px;
  }

  .photo-grid__subtitle {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-light);
  }

  .photo-placeholder {
    background: var(--color-bg-light);
    aspect-ratio: 4/5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .photo-placeholder--tall {
    aspect-ratio: 3/4;
  }

  .photo-placeholder span {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-accent);
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .photo-grid__inner {
      grid-template-columns: 1fr;
    }

    .photo-grid__stack {
      padding-top: 0;
    }
  }
</style>
