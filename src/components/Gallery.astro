---
const images = [
  { label: "Mountain Wedding", aspect: "3/4" },
  { label: "Gala Night", aspect: "4/5" },
  { label: "Birthday Celebration", aspect: "1/1" },
  { label: "Holiday Party", aspect: "4/5" },
  { label: "Corporate Event", aspect: "3/4" },
  { label: "Anniversary", aspect: "1/1" },
];
---

<section id="gallery" class="gallery">
  <div class="container">
    <div class="gallery__header reveal">
      <p class="label">Our Work</p>
      <h2>Gallery</h2>
    </div>

    <div class="gallery__grid">
      {
        images.map((img, i) => (
          <div
            class="gallery__item reveal"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="gallery__img" style={`aspect-ratio: ${img.aspect}`}>
              <span>{img.label}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: var(--section-padding) 0;
    background: var(--color-bg-light);
  }

  .gallery__header {
    text-align: center;
    margin-bottom: 80px;
  }

  .gallery__header .label {
    margin-bottom: 16px;
  }

  .gallery__grid {
    columns: 3;
    column-gap: 20px;
  }

  .gallery__item {
    break-inside: avoid;
    margin-bottom: 20px;
  }

  .gallery__img {
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.5s ease;
  }

  .gallery__item:hover .gallery__img {
    transform: scale(1.02);
  }

  .gallery__img span {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-accent);
    font-size: 1rem;
  }

  @media (max-width: 1024px) {
    .gallery__grid {
      columns: 2;
    }
  }

  @media (max-width: 600px) {
    .gallery__grid {
      columns: 1;
    }
  }
</style>
